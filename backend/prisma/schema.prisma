generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model TriviaQuestion {
  id         Int    @id @default(autoincrement())
  question   String
  optionA    String
  optionB    String
  optionC    String
  optionD    String
  correctIdx Int    // 0=A, 1=B, 2=C, 3=D
  category   String
  difficulty String @default("medium") // easy, medium, hard
}

model TriviaSession {
  id            String    @id @default(uuid())
  roundId       Int
  walletAddress String
  questionIds   Int[]     // ordered question IDs for this session
  answers       Int[]     // player's submitted answers (index per question)
  currentQ      Int       @default(0)
  score         Int       @default(0)
  startedAt     DateTime  @default(now())
  completedAt   DateTime?
  proofHash     String?
  submitted     Boolean   @default(false)

  @@index([roundId])
  @@index([walletAddress])
}

model LeaderboardEntry {
  id            Int      @id @default(autoincrement())
  game          String   // "word_duel" | "speed_trivia"
  walletAddress String
  wins          Int      @default(0)
  totalEarned   BigInt   @default(0)
  lastWinAt     DateTime?
  lastUpdated   DateTime @default(now())

  @@unique([game, walletAddress])
  @@index([game, wins(sort: Desc)])
}

model WordDuelSession {
  id            String    @id @default(uuid())
  roundId       Int
  walletAddress String
  letters       String
  foundWords    String[]
  score         Int       @default(0)
  startedAt     DateTime  @default(now())
  completedAt   DateTime?
  proofHash     String?
  submitted     Boolean   @default(false)

  @@index([roundId])
  @@index([walletAddress])
}

/// Stores the ONE shared letter set generated for each Word Pot round.
/// All players in the same round share this letter set — never regenerated.
model WordPotRound {
  id          Int      @id @default(autoincrement())
  roundId     Int      @unique
  letters     String   // shared by ALL players in this round
  generatedAt DateTime @default(now())

  @@index([roundId])
}

/// Per-player session in a Word Pot round.
model WordPotSession {
  id            String    @id @default(uuid())
  roundId       Int
  walletAddress String
  foundWords    String[]
  score         Int       @default(0)
  startedAt     DateTime  @default(now())
  completedAt   DateTime?
  proofHash     String?
  submitted     Boolean   @default(false)

  @@index([roundId])
  @@index([walletAddress])
}

model DailyChallengePlay {
  id            Int      @id @default(autoincrement())
  walletAddress String
  playedDate    String   // YYYY-MM-DD for unique checks
  playedAt      DateTime @default(now())
  score         Int
  targetScore   Int
  claimed       Boolean  @default(false)
  rewardAmount  String   // e.g. "1.00" (USDT)
  txHash        String?

  @@unique([walletAddress, playedDate])
}

model WordPotDailyLetters {
  date    String @id // YYYY-MM-DD
  letters String
}

model WordPotDaily {
  id            Int       @id @default(autoincrement())
  walletAddress String
  date          String    // YYYY-MM-DD
  foundWords    String[]
  score         Int       @default(0)
  completed     Boolean   @default(false)
  completedAt   DateTime?
  txHash        String?

  @@unique([walletAddress, date])
}
